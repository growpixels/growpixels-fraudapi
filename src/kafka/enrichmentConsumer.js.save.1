  messages: [{ value: JSON.stringify(enriched) }],
});

      await producer.send({
        topic: OUTPUT_TOPIC,
        messages: [
          {
            key: payload.id || null,
            value: JSON.stringify({
              ...payload,
              decision,
              audit,
              enriched_at: new Date().toISOString(),
            }),
          },
        ],
      });
    },
  });
}

start().catch((err) => {
  console.error("Consumer crashed", err);
  process.exit(1);
});
